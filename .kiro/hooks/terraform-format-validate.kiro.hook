{
  "enabled": true,
  "name": "Terraform Format & Validate",
  "description": "Automatically runs terraform fmt and terraform validate when Terraform files are saved",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "*.tf",
      "*.tfvars"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "terraform fmt -recursive && terraform validate"
  }
}